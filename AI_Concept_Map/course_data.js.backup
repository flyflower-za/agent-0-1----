\`\`\`python
# 安装：pip install numpy
import numpy as np

# Python List vs NumPy Array
py_list = [1, 2, 3]
np_arr = np.array([1, 2, 3])

print(type(np_arr)) # <class 'numpy.ndarray'>
\`\`\`

<h3>2. 创建矩阵的神器</h3>
<p>AI 模型初始化时，经常需要全0或全1的矩阵。</p>
\`\`\`python
# 1. 全 0 矩阵 (3行4列)
zeros = np.zeros((3, 4))

# 2. 全 1 矩阵
ones = np.ones((2, 3))

# 3. 随机矩阵 (模拟神经网络权重)
rand = np.random.rand(3, 3) 

# 4. 范围生成 (类似 range)
seq = np.arange(0, 10, 2) # [0, 2, 4, 6, 8]
\`\`\`

<h3>3. 核心属性</h3>
<p>拿到一个数据，先看它的“三围”。</p>
\`\`\`python
data = np.random.rand(5, 3)

print(data.ndim)   # 维度 (2)
print(data.shape)  # 形状 (5, 3) -> 5行3列
print(data.dtype)  # 类型 (float64)
\`\`\`
`
